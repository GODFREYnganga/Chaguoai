# ==========================================
# ChaguoAI - Open Source Configuration Template
# ==========================================
# Copy this file to .env and fill in your actual credentials.

# 1. Google Cloud Platform (GCP)
# ------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
# Path to your Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# Your Gemini API Key (Vertex AI or AI Studio)
GEMINI_API_KEY=your-gemini-api-key

# 2. OpenAI (For RAG Embeddings)
# ------------------------------------------
OPENAI_API_KEY=your-openai-key

# 3. Twilio (WhatsApp & SMS)
# ------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=your-twilio-sms-number
# Optional Twilio Content Template SIDs — one per option count (see mhc-docs/twilio_content_templates.md)
TWILIO_CONTENT_QUICK_REPLY_2_SID=your-2-button-quick-reply-sid
TWILIO_CONTENT_QUICK_REPLY_3_SID=your-3-button-quick-reply-sid
TWILIO_CONTENT_LIST_PICKER_4_SID=your-4-row-list-picker-sid
TWILIO_CONTENT_LIST_PICKER_5_SID=your-5-row-list-picker-sid
TWILIO_CONTENT_LIST_PICKER_7_SID=your-7-row-list-picker-sid
# Legacy aliases (optional — use _3 and _5 above instead)
TWILIO_CONTENT_QUICK_REPLY_SID=your-twilio-quick-reply-content-sid
TWILIO_CONTENT_LIST_PICKER_SID=your-twilio-list-picker-content-sid

# 4. Africa's Talking (USSD)
# ------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key

# 5. Flask Settings
# ------------------------------------------
FLASK_ENV=development
FLASK_SECRET_KEY=replace-with-a-long-random-secret
PORT=8080
# Update with your NGROK or Production URL
BASE_URL=http://localhost:8080

# 6. Firebase & Security
# ------------------------------------------
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
ADMIN_ACCESS_CODE=ADMIN2026

# 7. Knowledge Base Paths
# ------------------------------------------
# Paths relative to the mhc-backend directory
KENYA_FP_PDF="../mhc-knowledge/Signed National Family Planning Guidelines 7th Edition 2025 (1).pdf"
WHO_MEC_PDF="../mhc-knowledge/WHO MEC 6th Edition (2025).pdf"
WHO_SPR_PDF="../mhc-knowledge/WHO SPR 4th Edition (2025).pdf"

# 8. Background Jobs / Redis Queue
# ------------------------------------------
REDIS_URL=redis://your-render-redis-url
TRIAGE_QUEUE_NAME=triage
TRIAGE_JOB_TIMEOUT_SECONDS=180
TRIAGE_JOB_RESULT_TTL_SECONDS=3600
TRIAGE_JOB_FAILURE_TTL_SECONDS=86400

# 9. Gemini Runtime Bounds
# ------------------------------------------
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=20000
GEMINI_MAX_OUTPUT_TOKENS=900
# Gemini 2.5 Flash counts thinking tokens inside this budget — use 2048+ for WhatsApp.
WHATSAPP_MAX_OUTPUT_TOKENS=2048
WHATSAPP_RECOMMENDATION_MAX_WORDS=250
WEB_PROVIDER_MAX_OUTPUT_TOKENS=320
